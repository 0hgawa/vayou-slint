// Monochrome icons as SVG path data (24x24 viewbox), rendered with Slint's
// Path element. Same path data as the WebView build's icons.ts / inline SVGs,
// so the iconography is pixel-identical. `fill: currentColor` is emulated by
// the `color` property each call site sets.
export component AppIcon {
    in property <string> data;
    in property <brush> color: white;
    in property <length> size: 24px;
    width: size;
    height: size;
    Path {
        commands: root.data;
        fill: root.color;
        viewbox-width: 24;
        viewbox-height: 24;
        width: 100%;
        height: 100%;
    }
}

